{{#if page.attributes.revdate}}
<meta http-equiv="last-modified" content="{{page.attributes.revdate}}"/>
{{/if}}
<link rel="stylesheet" href="{{uiRootPath}}/css/search.css">
<link rel="icon" href="{{uiRootPath}}/img/favicon.ico" type="image/x-icon">
<link rel="stylesheet" href="{{uiRootPath}}/css/font-styles.css">
<link rel="stylesheet" href="{{uiRootPath}}/fonts/css/all.css">
<link rel="stylesheet" href="{{uiRootPath}}/css/site-extra.css">
<link rel="stylesheet" href="{{uiRootPath}}/css/api-styles.css">
<link rel="stylesheet" href="{{{uiRootPath}}}/css/vendor/tabs.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=SUSE:wght@100..800&display=swap" rel="stylesheet">
<meta content="width=device-width, initial-scale=1.0, user-scalable=yes" name="viewport"/>

<!-- JSON-LD structured data -->
{{#if page.description}}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": "{{page.title}}",
  "description": "{{page.description}}",
  "inLanguage": "en-US",
  "author": {
    "@type": "Organization",
    "name": "Uyuni Project"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Uyuni Project",
    "url": "https://www.uyuni-project.org"
  }
}
</script>
{{/if}}
